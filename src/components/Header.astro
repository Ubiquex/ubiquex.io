---
---

<header class="nav">
  <a href="/" class="nav-logo">
    <img src="/logo.png" alt="ubiquex" height="36" />
  </a>
  <nav>
    <ul class="nav-links">
      <li><a href="https://docs.ubiquex.io" class="nav-cta">Get started →</a></li>
    </ul>
  </nav>
</header>

<style>
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 48px;
    height: 64px;
    background: rgba(13, 17, 23, 0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--ubx-border);
  }

  .nav-logo img {
    display: block;
    height: 36px;
    width: auto;
  }

  .nav-links { display: flex; align-items: center; gap: 32px; list-style: none; }
  .nav-links a { color: var(--ubx-muted); font-size: 14px; font-weight: 500; transition: color 0.2s; }
  .nav-links a:hover { color: var(--ubx-text); }
  .nav-cta {
    background: var(--ubx-green) !important;
    color: var(--ubx-bg) !important;
    padding: 8px 20px;
    border-radius: var(--ubx-radius-sm);
    font-weight: 600 !important;
  }
  .nav-cta:hover { background: #00BFA5 !important; }

  @media (max-width: 768px) {
    .nav { padding: 0 20px; }
    .nav-hide { display: none; }
    .nav-logo img { height: 28px; }
  }
</style>
