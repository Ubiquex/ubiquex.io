---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'ubiquex — Infrastructure as Code. Wired natively.',
  description = 'An HCL-inspired IaC language that compiles to Pulumi TypeScript.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />
  </body>
</html>
