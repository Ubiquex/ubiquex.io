---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";
import Hero from "@/components/widgets/Hero.astro";
import Features from "@/components/widgets/Features.astro";
import Github from "@/components/widgets/Github.astro";
import { Icon } from "astro-icon/components";
import CodeDemo from "@/components/widgets/CodeDemo.astro";
const metadata = {
  title: "Ubiquex — Infra and apps, shipped as one",
  description: "Provision. Deploy. Govern. Everywhere. Platform engineering, ubiquitous by design.",
  ignoreTitleTemplate: true,
};
---

<BaseLayout {metadata}>
  <Hero
    title={`Infra and apps, <br class="hidden md:block" /> <span class="bg-linear-to-r from-[#00A693] via-[#00BFA8] to-[#57C5C6] bg-clip-text text-transparent">shipped as one</span>`}
    tagline="Now in Public Preview"
    description={`${siteConfig.description}`}
  >
    <div class="mt-10 w-full">
      <CodeDemo />
    </div>

    <!-- Stats bar -->
    <div class="w-full mt-12 pt-12 border-t border-border">
      <div class="text-center mb-10">
        <p class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-semibold mb-4">By the numbers</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight">Built on a solid foundation</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
        <div class="flex flex-col items-center text-center gap-2">
          <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-muted text-muted-foreground">
            <Icon name="lucide:plug" class="w-5 h-5" />
          </div>
          <span class="text-sm font-semibold text-foreground">+100 providers</span>
        </div>
        <div class="flex flex-col items-center text-center gap-2">
          <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-muted text-muted-foreground">
            <Icon name="lucide:shield-off" class="w-5 h-5" />
          </div>
          <span class="text-sm font-semibold text-foreground">No Terraform BSL</span>
        </div>
        <div class="flex flex-col items-center text-center gap-2">
          <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-muted text-muted-foreground">
            <Icon name="lucide:layers" class="w-5 h-5" />
          </div>
          <span class="text-sm font-semibold text-foreground">Pulumi-powered</span>
        </div>
        <div class="flex flex-col items-center text-center gap-2">
          <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-muted text-muted-foreground">
            <Icon name="lucide:sparkles" class="w-5 h-5" />
          </div>
          <span class="text-sm font-semibold text-foreground">AI plan summaries</span>
        </div>
        <div class="flex flex-col items-center text-center gap-2">
          <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-muted text-muted-foreground">
            <Icon name="lucide:unplug" class="w-5 h-5" />
          </div>
          <span class="text-sm font-semibold text-foreground">Zero glue code</span>
        </div>
        <div class="flex flex-col items-center text-center gap-2">
          <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-muted text-muted-foreground">
            <Icon name="lucide:scale" class="w-5 h-5" />
          </div>
          <span class="text-sm font-semibold text-foreground">Apache 2.0</span>
        </div>
      </div>
    </div>

  </Hero>
  <Features
    tagline="Features"
    title="Built differently"
    subtitle="Infrastructure and application delivery in one language with no glue code for developers happiness."
    features={[
      {
        title: "HCL-inspired Language",
        description:
          "Write infrastructure in a clean, readable DSL that compiles to Pulumi TypeScript, Python, or Go. No YAML sprawl, no SDK boilerplate.",
        icon: "lucide:file-code-2",
        iconClass: "bg-[#00A693]/10 text-[#00A693]",
      },
      {
        title: "Built-in AI",
        description:
          "Get plain-English plan summaries, cost estimates, and security suggestions — powered by Claude, right in your terminal.",
        icon: "lucide:sparkles",
        iconClass: "bg-[#FE28A2]/10 text-[#FE28A2]",
      },
      {
        title: "Pulumi at the Core",
        description:
          "ubx compiles to native Pulumi programs. Every provider, every resource, every state backend — all Pulumi-compatible out of the box.",
        icon: "lucide:layers",
        iconClass: "bg-[#0067A5]/10 text-[#0067A5]",
      },
      {
        title: "Pending\u003cT\u003e Type System",
        description:
          "Wire infrastructure outputs directly into app config with the ~ sigil. ubx tracks Pending\u003cT\u003e values and generates the right .apply() chains automatically.",
        icon: "lucide:git-branch",
        iconClass: "bg-[#D99058]/10 text-[#D99058]",
      },
      {
        title: "Policy as Code & Tests",
        description:
          "Enforce security rules and write plan-time assertions in .iac source. Catch misconfigurations before credentials are ever needed.",
        icon: "lucide:shield-check",
        iconClass: "bg-[#C81D11]/10 text-[#C81D11]",
      },
      {
        title: "One Source, Any Runtime",
        description:
          "The same .iac files compile to TypeScript, Python, or Go. Switch runtimes without rewriting a single resource block.",
        icon: "lucide:repeat-2",
        iconClass: "bg-[#FE28A2]/10 text-[#FE28A2]",
      },
    ]}
  />


  <!-- Who is ubx for — tabbed -->
  <div class="relative mx-auto max-w-7xl px-4 md:px-6 py-20 md:py-28">
    <div class="text-center mb-12">
      <p class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-semibold mb-4">Who it's for</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Built for everyone who ships</h2>
      <p class="text-muted-foreground text-lg max-w-2xl mx-auto">Whether you write the code or own the platform, ubx speaks your language.</p>
    </div>

    <!-- Tab buttons -->
    <div class="flex justify-center mb-10">
      <div class="inline-flex rounded-xl border border-border p-1 bg-muted gap-1">
        <button id="tab-dev" class="tab-btn px-6 py-2 rounded-lg text-sm font-semibold transition-all bg-background text-foreground shadow">
          For Developers
        </button>
        <button id="tab-pe" class="tab-btn px-6 py-2 rounded-lg text-sm font-semibold transition-all text-muted-foreground hover:text-foreground">
          For Platform Engineers
        </button>
      </div>
    </div>

    <!-- Developers panel -->
    <div id="panel-dev" class="grid md:grid-cols-3 gap-6">
      <div class="flex gap-5 p-6 rounded-xl bg-card border-l-4 border-[#00A693] border border-border">
        <div class="shrink-0 flex items-center justify-center w-11 h-11 rounded-lg bg-[#00A693]/10 text-[#00A693]">
          <Icon name="lucide:unplug" class="w-5 h-5" />
        </div>
        <div>
          <h3 class="font-semibold mb-1">No more glue scripts</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">Wire a DB endpoint into Helm values with <code class="text-[#00A693] text-xs">~</code>. ubx generates the sequencing — no CI steps, no copy-paste, no drift.</p>
        </div>
      </div>
      <div class="flex gap-5 p-6 rounded-xl bg-card border-l-4 border-[#0067A5] border border-border">
        <div class="shrink-0 flex items-center justify-center w-11 h-11 rounded-lg bg-[#0067A5]/10 text-[#0067A5]">
          <Icon name="lucide:shield-check" class="w-5 h-5" />
        </div>
        <div>
          <h3 class="font-semibold mb-1">Catch errors before apply</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">ubx validate type-checks your entire stack in milliseconds — no cloud credentials, no network, no surprises in production.</p>
        </div>
      </div>
      <div class="flex gap-5 p-6 rounded-xl bg-card border-l-4 border-[#FE28A2] border border-border">
        <div class="shrink-0 flex items-center justify-center w-11 h-11 rounded-lg bg-[#FE28A2]/10 text-[#FE28A2]">
          <Icon name="lucide:repeat-2" class="w-5 h-5" />
        </div>
        <div>
          <h3 class="font-semibold mb-1">Write once, run anywhere</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">Same .iac source compiles to TypeScript, Python, or Go. Use the language your team already knows — no rewrite needed.</p>
        </div>
      </div>
    </div>

    <!-- Platform Engineers panel -->
    <div id="panel-pe" class="grid md:grid-cols-3 gap-6 hidden">
      <div class="flex gap-5 p-6 rounded-xl bg-card border-l-4 border-[#00A693] border border-border">
        <div class="shrink-0 flex items-center justify-center w-11 h-11 rounded-lg bg-[#00A693]/10 text-[#00A693]">
          <Icon name="lucide:layers" class="w-5 h-5" />
        </div>
        <div>
          <h3 class="font-semibold mb-1">One language, full stack</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">Provision, deploy, sync, govern, test — all in .iac. No context switching between Terraform, Helm, ArgoCD, and policy tools.</p>
        </div>
      </div>
      <div class="flex gap-5 p-6 rounded-xl bg-card border-l-4 border-[#C81D11] border border-border">
        <div class="shrink-0 flex items-center justify-center w-11 h-11 rounded-lg bg-[#C81D11]/10 text-[#C81D11]">
          <Icon name="lucide:file-lock-2" class="w-5 h-5" />
        </div>
        <div>
          <h3 class="font-semibold mb-1">Policy and compliance built in</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">Enforce security rules at validate time — before any credentials touch the cloud. Policies live alongside the resources they govern.</p>
        </div>
      </div>
      <div class="flex gap-5 p-6 rounded-xl bg-card border-l-4 border-[#FE28A2] border border-border">
        <div class="shrink-0 flex items-center justify-center w-11 h-11 rounded-lg bg-[#FE28A2]/10 text-[#FE28A2]">
          <Icon name="lucide:sparkles" class="w-5 h-5" />
        </div>
        <div>
          <h3 class="font-semibold mb-1">AI-powered planning</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">Cost estimates, plain-English summaries, and risk analysis before you apply — powered by Claude, right in your terminal.</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function() {
      function switchTab(tab) {
        var devBtn = document.getElementById('tab-dev');
        var peBtn = document.getElementById('tab-pe');
        var devPanel = document.getElementById('panel-dev');
        var pePanel = document.getElementById('panel-pe');
        if (!devBtn || !peBtn || !devPanel || !pePanel) return;
        if (tab === 'dev') {
          devBtn.classList.add('bg-background', 'text-foreground', 'shadow');
          devBtn.classList.remove('text-muted-foreground');
          peBtn.classList.remove('bg-background', 'text-foreground', 'shadow');
          peBtn.classList.add('text-muted-foreground');
          devPanel.classList.remove('hidden');
          pePanel.classList.add('hidden');
        } else {
          peBtn.classList.add('bg-background', 'text-foreground', 'shadow');
          peBtn.classList.remove('text-muted-foreground');
          devBtn.classList.remove('bg-background', 'text-foreground', 'shadow');
          devBtn.classList.add('text-muted-foreground');
          pePanel.classList.remove('hidden');
          devPanel.classList.add('hidden');
        }
      }
      document.addEventListener('astro:page-load', function() {
        var devBtn = document.getElementById('tab-dev');
        var peBtn = document.getElementById('tab-pe');
        if (devBtn) devBtn.addEventListener('click', function() { switchTab('dev'); });
        if (peBtn) peBtn.addEventListener('click', function() { switchTab('pe'); });
      });
    })();
  </script>

  <Github
    title="Star ubx on GitHub"
    subtitle="ubx is open source under the Apache 2.0 license. Star the repo to follow development and help others discover it."
    tagline="Open Source"
    icon="lucide:github"
    actions={[
      {
        text: "Star on GitHub",
        href: "https://github.com/ubiquex/ubx",
        variant: "primary",
        icon: "lucide:star",
      },
      {
        text: "Read the docs",
        href: "https://docs.ubiquex.io",
        variant: "secondary",
        icon: "lucide:book-open",
      },
    ]}
  />
</BaseLayout>
