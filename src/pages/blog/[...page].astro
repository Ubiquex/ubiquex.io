---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Pagination from "@/components/ui/Pagination.astro";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const blogEntries = await getCollection("blog");
  const sortedPosts = blogEntries
    .filter((post) => post.data && post.data.pubDate)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return paginate(sortedPosts, { pageSize: 6 });
}

const { page } = Astro.props;
const blog = page.data;

const metadata = {
  title: "Blog — Ubiquex",
  description: "Latest news, announcements, and updates from the Ubiquex team.",
};

const postsWithTime = await Promise.all(
  blog.map(async (post) => {
    const { remarkPluginFrontmatter } = await render(post);
    const readingTime = remarkPluginFrontmatter?.minutesRead
      ? `${Math.ceil(remarkPluginFrontmatter.minutesRead)} min read`
      : "";
    return { post, readingTime };
  })
);

const featured = postsWithTime[0];
const rest = postsWithTime.slice(1);
---

<BaseLayout metadata={metadata}>
  <section class="relative px-4 py-16 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="mx-auto max-w-5xl mb-16 text-center">
      <p class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-semibold mb-4">From the team</p>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-foreground mb-4">What we're thinking about</h1>
      <p class="text-lg text-muted-foreground max-w-xl mx-auto">Announcements, deep dives, and engineering notes from the people building ubx.</p>
    </div>

    <div class="mx-auto max-w-5xl">

      <!-- Featured post -->
      {featured && (
        <a href={`/blog/${featured.post.id}`} class="group block mb-16">
          <div class="rounded-2xl border border-border bg-card overflow-hidden hover:border-primary/40 transition-colors duration-200">
            <div class="flex flex-col md:flex-row">
            {featured.post.data.image && (
              <div class="md:w-2/5 shrink-0 overflow-hidden">
                <img
                  src={featured.post.data.image}
                  alt={featured.post.data.title}
                  class="h-64 md:h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                />
              </div>
            )}
            <div class="p-8 md:p-12 flex flex-col justify-center">
              <div class="flex items-center gap-3 mb-6">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-primary/10 text-primary border border-primary/20">
                  {featured.post.data.category || "Announcement"}
                </span>
                <span class="text-xs text-muted-foreground">
                  {featured.post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric", timeZone: "UTC" })}
                </span>
                {featured.readingTime && <span class="text-xs text-muted-foreground">· {featured.readingTime}</span>}
              </div>
              <h2 class="text-2xl md:text-4xl font-bold text-foreground mb-4 group-hover:text-primary transition-colors">
                {featured.post.data.title}
              </h2>
              <p class="text-muted-foreground text-lg leading-relaxed mb-8 max-w-3xl">
                {featured.post.data.description}
              </p>
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium text-foreground">{featured.post.data.author}</span>
                <span class="text-sm font-semibold text-primary group-hover:underline">Read more →</span>
              </div>
            </div>
            </div>
          </div>
        </a>
      )}

      <!-- Rest of posts -->
      {rest.length > 0 && (
        <div class="grid md:grid-cols-2 gap-6">
          {rest.map(({ post, readingTime }) => (
            <a href={`/blog/${post.id}`} class="group block">
              <div class="rounded-xl border border-border bg-card p-6 h-full hover:border-primary/40 transition-colors duration-200">
                <div class="flex items-center gap-2 mb-4">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-muted text-muted-foreground">
                    {post.data.category || "Post"}
                  </span>
                  <span class="text-xs text-muted-foreground">
                    {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric", timeZone: "UTC" })}
                  </span>
                </div>
                <h3 class="text-lg font-semibold text-foreground mb-2 group-hover:text-primary transition-colors">
                  {post.data.title}
                </h3>
                <p class="text-sm text-muted-foreground line-clamp-3 mb-4">
                  {post.data.description}
                </p>
                <div class="flex items-center justify-between">
                  <span class="text-xs text-muted-foreground">{post.data.author}{readingTime ? ` · ${readingTime}` : ""}</span>
                  <span class="text-xs font-semibold text-primary group-hover:underline">Read →</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}

      <Pagination page={page} />
    </div>

  </section>
</BaseLayout>
